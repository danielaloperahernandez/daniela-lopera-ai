# ============================================================================
# AI Automation Portfolio - environment configuration
# Copy to `.env` and fill in the values you need. Never commit `.env`.
# ============================================================================

# ---- LLM provider selection -------------------------------------------------
# Which provider the multi-provider core uses. One of: openai | anthropic | gemini
LLM_PROVIDER=openai

# Chat model per provider (override the defaults if you like)
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
GEMINI_CHAT_MODEL=gemini-1.5-flash

# ---- Embeddings -------------------------------------------------------------
# Embeddings always run through OpenAI by default (stable + cheap).
# Set EMBEDDINGS_PROVIDER=gemini to use Google embeddings instead.
EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
GEMINI_EMBEDDINGS_MODEL=text-embedding-004

# ---- API keys (only the ones for the providers you use) --------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# ---- Qdrant vector database -------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=portfolio_knowledge

# ---- Project 1: Document Intelligence API ----------------------------------
DOC_API_HOST=0.0.0.0
DOC_API_PORT=8000
# Shared secret expected in the `x-api-key` header (n8n sends this).
DOC_API_KEY=change-me-local-dev

# ---- Project 2: Autonomous Support Agent (n8n) -----------------------------
# Set inside n8n credentials; listed here for reference only.
TELEGRAM_BOT_TOKEN=
# Base URL n8n uses to reach the RAG API (Project 1/3).
RAG_API_URL=http://host.docker.internal:8000

# ---- Generation tuning ------------------------------------------------------
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=5
LLM_REQUEST_TIMEOUT=60
