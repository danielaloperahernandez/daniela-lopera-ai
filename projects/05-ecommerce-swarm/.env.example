# LLM
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro

# Shopify Admin API REST (Custom App — ver README)
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_PATH=./data/chroma_db
CHROMA_COLLECTION=ecommerce_kb

# Opcional: webhook para notificar escaladas (Slack, n8n, etc.)
ESCALATION_WEBHOOK_URL=
WHATSAPP_ESCALATION_TEMPLATE=escalacion_soporte

# Límites
RATE_LIMIT_MESSAGES_PER_MINUTE=10
IDEMPOTENCY_TTL_SECONDS=60
SESSION_TTL_SECONDS=86400
RAG_SCORE_THRESHOLD=0.75

# LangSmith (opcional — trazabilidad en smith.langchain.com)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ecommerce-eval
